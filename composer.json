{
    "name": "arcwp/gateway",
    "require": {
        "php": ">=8.2",
        "illuminate/database": "*",
        "anthropic-ai/sdk": "^0.3.0",
        "symfony/http-client": "^7.3",
        "nyholm/psr7": "^1.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload-dev": {
        "psr-4": {
            "Gateway\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html coverage"
    }
}
