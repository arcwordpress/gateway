{
  "name": "@gateway/grid",
  "version": "1.0.0",
  "description": "Gateway Grid React component library with TanStack Table",
  "main": "dist/lib.js",
  "module": "dist/lib.js",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "wp-scripts build src/lib.js --output-path=dist",
    "build:standalone": "wp-scripts build src/index.js --output-path=build",
    "start": "wp-scripts start src/lib.js --output-path=dist",
    "start:standalone": "wp-scripts start src/index.js --output-path=build",
    "check-engines": "wp-scripts check-engines",
    "check-licenses": "wp-scripts check-licenses",
    "lint:css": "wp-scripts lint-style",
    "lint:js": "wp-scripts lint-js",
    "lint:pkg-json": "wp-scripts lint-pkg-json"
  },
  "devDependencies": {
    "@wordpress/scripts": "^27.0.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.14"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.14",
    "@tanstack/react-table": "^8.20.5",
    "axios": "^1.6.2"
  },
  "peerDependencies": {
    "@wordpress/element": "^5.0.0 || ^6.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
