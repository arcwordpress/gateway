{
  "presets": [
    ["@babel/preset-env", {
      "modules": false,
      "targets": {
        "esmodules": true
      }
    }],
    ["@babel/preset-react", {
      "runtime": "automatic"
    }]
  ],
  "plugins": [
    "@babel/plugin-transform-export-namespace-from",
    ["module-resolver", {
      "root": ["./src"],
      "alias": {
        "@arcwp/gateway-data": "./src/data",
        "@arcwp/gateway-forms": "./src/forms",
        "@wordpress/i18n": "./src/forms/i18n"
      }
    }]
  ],
  "env": {
    "test": {
      "presets": [
        ["@babel/preset-env", {
          "targets": { "node": "current" }
        }],
        ["@babel/preset-react", {
          "runtime": "automatic"
        }]
      ]
    }
  }
}
