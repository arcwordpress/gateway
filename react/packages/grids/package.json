{
  "name": "@arcwp/gateway-grids",
  "version": "1.2.3",
  "description": "Gateway Grid React component library with TanStack Table",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "style": "dist/style.css",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./style.css": "./dist/style.css",
    "./board-styles.css": "./dist/board-styles.css"
  },
  "author": "ARCWP <hello@arcwp.ca>",
  "license": "MIT",
  "scripts": {
    "build": "babel src --out-dir dist --copy-files --ignore '**/*.test.js','**/*.spec.js'",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "gateway",
    "grid",
    "react",
    "wordpress",
    "components",
    "tanstack-table"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/arcwordpress/gateway-grid.git"
  },
  "bugs": {
