  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@babel/cli": "^7.24.0",
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0"
  },
  "dependencies": {
    "@arcwp/gateway-forms": "^1.2.5",
    "@tanstack/react-table": "^8.20.5",
    "@asseinfo/react-kanban": "^2.2.0",
    "axios": "^1.6.2"
  },
  "peerDependencies": {
