{
  "name": "@arcwp/gateway-data",
  "version": "1.0.1",
  "description": "Shared data layer for Gateway collections - provides unified API access and state management",
  "main": "src/index.js",
  "module": "src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./src/index.js"
    }
  },
  "scripts": {
