{
  "plugins": ["@babel/plugin-transform-export-namespace-from"],
  "presets": [
    ["@babel/preset-env", {
      "modules": false,
      "targets": {
        "esmodules": true
      }
    }],
    ["@babel/preset-react", {
      "runtime": "classic",
      "pragma": "wp.element.createElement",
      "pragmaFrag": "wp.element.Fragment"
    }]
  ]
}