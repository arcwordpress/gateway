{
  "name": "@arcwp/gateway-forms",
  "version": "1.2.6",
  "description": "Gateway Forms React component library with form field types and validation",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "style": "dist/style.css",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "author": "ARCWP <hello@arcwp.ca>",
  "license": "MIT",
  "scripts": {
    "build": "babel src --out-dir dist --copy-files --ignore '**/*.test.js','**/*.spec.js'",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "gateway",
    "forms",
    "react",
    "wordpress",
    "components",
    "form-validation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/arcwordpress/gateway-forms.git"
  },
  "bugs": {
    "url": "https://github.com/arcwordpress/gateway-forms/issues"
  },
  "homepage": "https://github.com/arcwordpress/gateway-forms#readme",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@babel/cli": "^7.24.0",
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "babel-plugin-module-resolver": "^5.0.2"
  },
  "dependencies": {
    "@arcwp/gateway-data": "file:../data",
    "@hookform/resolvers": "^3.3.4",
    "@tiptap/extension-link": "^3.6.6",
    "@tiptap/extension-text-align": "^3.6.6",
    "@tiptap/extension-underline": "^3.6.6",
    "@tiptap/react": "^3.6.6",
    "@tiptap/starter-kit": "^3.6.6",
    "easymde": "^2.20.0",
    "react-datepicker": "^8.7.0",
    "react-hook-form": "^7.49.2",
    "react-simplemde-editor": "^5.2.0",
    "zod": "^3.22.4"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
