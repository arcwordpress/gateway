{
  "presets": [
    ["@babel/preset-env", {
      "modules": false,
      "targets": {
        "esmodules": true
      }
    }],
    ["@babel/preset-react", {
      "runtime": "classic",
      "pragma": "wp.element.createElement",
      "pragmaFrag": "wp.element.Fragment"
    }]
  ],
  "plugins": [
    ["module-resolver", {
      "alias": {
        "@arcwp/gateway-forms": "./src"
      }
    }]
  ],
  "env": {
    "test": {
      "presets": [
        ["@babel/preset-env", {
          "targets": { "node": "current" }
        }],
        ["@babel/preset-react", {
          "runtime": "automatic"
        }]
      ]
    }
  }
}