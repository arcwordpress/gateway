{
  "name": "@arcwp/gateway-react",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "overrides": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0"
  },
  "scripts": {
    "build": "npm run build:packages && npm run build:apps",
    "build:packages": "npm run build -w packages/gateway",
    "build:apps": "npm --prefix apps run build"
  }
}
