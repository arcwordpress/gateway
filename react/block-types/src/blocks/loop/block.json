{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "gateway/loop",
	"version": "0.1.0",
	"title": "Gateway Loop",
	"category": "gateway",
	"icon": "controls-repeat",
	"description": "Repeats a block template over every record from a data source. Click any item to edit the shared template.",
	"textdomain": "gateway",
	"attributes": {
		"dataSource": {
			"type": "string",
			"default": ""
		}
	},
	"supports": {
		"html": false
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css"
}
