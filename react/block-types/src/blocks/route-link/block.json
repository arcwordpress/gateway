{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gateway/route-link",
  "title": "Route Link",
  "category": "gateway",
  "icon": "admin-links",
  "description": "A link that navigates to a different route within the router.",
  "keywords": ["link", "navigation", "route", "router"],
  "attributes": {
    "path": {
      "type": "string",
      "default": "/"
    },
    "label": {
      "type": "string",
      "default": "Link"
    }
  },
  "supports": {
    "html": false,
    "interactivity": true,
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "textdomain": "gateway"
}
