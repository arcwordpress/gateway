{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gateway/facet-search",
  "title": "Facet Search",
  "category": "gateway",
  "icon": "search",
  "description": "A text search filter inside a Facet Group. Leave the field key blank to search all fields.",
  "parent": ["gateway/facet-group"],
  "attributes": {
    "fieldKey": {
      "type": "string",
      "default": ""
    },
    "label": {
      "type": "string",
      "default": "Search"
    },
    "placeholder": {
      "type": "string",
      "default": "Search…"
    }
  },
  "supports": {
    "html": false,
    "reusable": false,
    "interactivity": true
  },
  "editorScript": "file:./index.js",
  "textdomain": "gateway"
}
