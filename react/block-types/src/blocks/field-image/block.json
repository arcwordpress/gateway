{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gateway/field-image",
  "title": "Field Image",
  "category": "gateway",
  "icon": "format-image",
  "description": "Renders an image from a collection record field via the Interactivity API.",
  "parent": ["gateway/column"],
  "attributes": {
    "fieldKey": {
      "type": "string",
      "default": ""
    },
    "altKey": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "html": false,
    "reusable": false,
    "interactivity": true
  },
  "editorScript": "file:./index.js",
  "textdomain": "gateway"
}
