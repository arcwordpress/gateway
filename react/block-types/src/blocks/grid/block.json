{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gateway/grid",
  "title": "Gateway Grid",
  "category": "gateway",
  "icon": "grid-view",
  "description": "Gateway data grid. Loads all records for a collection and renders them via the Interactivity API.",
  "attributes": {
    "collectionSlug": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "html": false,
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "viewScriptModule": "file:./view.js"
}
