{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gateway/gateway-grid",
  "title": "Gateway Grid",
  "category": "gateway",
  "icon": "grid-view",
  "description": "Monolithic grid block for Gateway collections. Loads all records into a store (store.data), supports status-based filtering that populates store.records, and renders via WordPress Interactivity API.",
  "attributes": {
    "collectionSlug": {
      "type": "string",
      "default": ""
    },
    "previewTotalCount": {
      "type": "integer",
      "default": 0
    },
    "previewFilteredCount": {
      "type": "integer",
      "default": 0
    },
    "previewIsConfigured": {
      "type": "boolean",
      "default": false
    }
  },
  "providesContext": {
    "gateway/totalCount":    "previewTotalCount",
    "gateway/filteredCount": "previewFilteredCount",
    "gateway/isConfigured":  "previewIsConfigured"
  },
  "allowedBlocks": ["gateway/filter-group", "gateway/grid-summary", "gateway/grid-records"],
  "supports": {
    "html": false,
    "interactivity": true,
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "viewScriptModule": "file:./view.js"
}
