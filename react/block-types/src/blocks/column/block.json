{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gateway/column",
  "title": "Column",
  "category": "gateway",
  "icon": "table-col-after",
  "description": "A cell inside a Heading row or a data Row. Set a label (for headers) and a field key, then add field blocks inside to display data.",
  "parent": ["gateway/heading", "gateway/row"],
  "allowedBlocks": [
    "gateway/field-text",
    "gateway/field-image",
    "gateway/field-date",
    "gateway/field-link",
    "gateway/field-badge"
  ],
  "attributes": {
    "label": {
      "type": "string",
      "default": ""
    },
    "fieldKey": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "html": false,
    "reusable": false
  },
  "editorScript": "file:./index.js",
  "textdomain": "gateway"
}
