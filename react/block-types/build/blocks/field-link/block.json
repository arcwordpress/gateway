{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gateway/field-link",
  "title": "Field Link",
  "category": "gateway",
  "icon": "admin-links",
  "description": "Renders a link from a collection record field via the Interactivity API.",
  "parent": [
    "gateway/column"
  ],
  "attributes": {
    "fieldKey": {
      "type": "string",
      "default": ""
    },
    "labelKey": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "html": false,
    "reusable": false,
    "interactivity": true
  },
  "editorScript": "file:./index.js",
  "textdomain": "gateway"
}