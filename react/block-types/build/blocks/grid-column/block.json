{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gateway/grid-column",
  "title": "Grid Column",
  "category": "gateway",
  "icon": "table-col-after",
  "description": "Defines a single column in a Gateway Grid: the data field key to bind and the display label shown in the header.",
  "parent": [
    "gateway/grid-columns"
  ],
  "attributes": {
    "fieldKey": {
      "type": "string",
      "default": ""
    },
    "label": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "html": false,
    "reusable": false
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "textdomain": "gateway"
}