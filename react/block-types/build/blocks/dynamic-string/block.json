{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gateway/string",
  "version": "0.1.0",
  "title": "String",
  "category": "gateway",
  "icon": "text",
  "description": "A dynamic string block that binds to interactive data using wp-text.",
  "example": {},
  "supports": {
    "html": false,
    "interactivity": true
  },
  "usesContext": [
    "gateway/collectionSlug",
    "gateway/previewItems",
    "gateway/availableFields",
    "gateway/fieldDefinitions",
    "gateway/itemName",
    "gateway/inLoop"
  ],
  "textdomain": "gateway",
  "editorScript": "file:./index.js",
  "attributes": {
    "contextNamespace": {
      "type": "string",
      "default": ""
    },
    "fieldKey": {
      "type": "string",
      "default": ""
    },
    "useAdvancedPath": {
      "type": "boolean",
      "default": false
    },
    "propertyPath": {
      "type": "string",
      "default": ""
    },
    "fallbackText": {
      "type": "string",
      "default": ""
    },
    "wrapperElement": {
      "type": "string",
      "default": ""
    }
  }
}