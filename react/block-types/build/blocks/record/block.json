{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gateway/record",
  "title": "Record",
  "category": "gateway",
  "icon": "admin-page",
  "description": "Fetch and display a single record from a Gateway collection. Works with dynamic routing to load records by slug or ID.",
  "keywords": [
    "record",
    "single",
    "detail",
    "course",
    "lesson",
    "post"
  ],
  "attributes": {
    "collectionSlug": {
      "type": "string",
      "default": ""
    },
    "recordId": {
      "type": "string",
      "default": ""
    },
    "recordSlug": {
      "type": "string",
      "default": ""
    },
    "lookupField": {
      "type": "string",
      "default": "slug",
      "enum": [
        "id",
        "slug"
      ]
    },
    "useRouteParam": {
      "type": "boolean",
      "default": true
    },
    "routeParamName": {
      "type": "string",
      "default": "slug"
    },
    "namespace": {
      "type": "string",
      "default": "gateway/record"
    },
    "previewRecord": {
      "type": "object",
      "default": {}
    },
    "availableFields": {
      "type": "array",
      "default": []
    },
    "fieldDefinitions": {
      "type": "object",
      "default": {}
    }
  },
  "providesContext": {
    "gateway/item": "previewRecord",
    "gateway/recordFields": "availableFields",
    "gateway/fieldDefinitions": "fieldDefinitions"
  },
  "supports": {
    "html": false,
    "interactivity": true,
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "viewScriptModule": "file:./view.js",
  "textdomain": "gateway"
}