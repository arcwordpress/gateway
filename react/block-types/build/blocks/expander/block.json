{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gateway/gtx-expander",
  "title": "GTX Expander",
  "category": "gateway",
  "icon": "arrow-down-alt2",
  "description": "An expandable content block with heading and body sections.",
  "attributes": {
    "isOpen": {
      "type": "boolean",
      "default": false
    }
  },
  "supports": {
    "html": false,
    "interactivity": true
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "textdomain": "gateway"
}