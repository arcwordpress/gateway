{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gateway/router",
  "title": "Router",
  "category": "gateway",
  "icon": "admin-links",
  "description": "A client-side router container. Add route blocks inside to define routable views.",
  "keywords": [
    "router",
    "navigation",
    "spa",
    "route"
  ],
  "attributes": {
    "namespace": {
      "type": "string",
      "default": "gateway/router"
    },
    "defaultRoute": {
      "type": "string",
      "default": "/"
    }
  },
  "supports": {
    "html": false,
    "interactivity": true,
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "viewScriptModule": "file:./view.js",
  "textdomain": "gateway"
}