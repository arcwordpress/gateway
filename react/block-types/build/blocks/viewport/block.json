{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gateway/gtx-viewport",
  "version": "1.0.0",
  "title": "GTX Viewport",
  "category": "gateway",
  "icon": "visibility",
  "description": "A container block that detects when it enters the viewport and provides context to child blocks for animation triggers.",
  "attributes": {
    "inViewport": {
      "type": "boolean",
      "default": false
    }
  },
  "supports": {
    "html": false,
    "interactivity": true
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "viewScriptModule": "file:./view.js",
  "textdomain": "gateway"
}