{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gateway/data-source",
  "version": "0.1.0",
  "title": "Data Source",
  "category": "gateway",
  "icon": "list-view",
  "description": "A single collection fetch. Assign an optional key to reference this data in routes and templates.",
  "textdomain": "gateway",
  "parent": [
    "gateway/data"
  ],
  "attributes": {
    "collection": {
      "type": "string",
      "default": ""
    },
    "dataKey": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "html": false,
    "reusable": false
  },
  "editorScript": "file:./index.js"
}