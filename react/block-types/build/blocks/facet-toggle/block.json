{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gateway/facet-toggle",
  "title": "Facet Toggle",
  "category": "gateway",
  "icon": "yes-alt",
  "description": "A checkbox toggle filter inside a Facet Group. Includes or excludes records where a field matches a specific value.",
  "parent": [
    "gateway/facet-group"
  ],
  "attributes": {
    "fieldKey": {
      "type": "string",
      "default": ""
    },
    "filterValue": {
      "type": "string",
      "default": ""
    },
    "label": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "html": false,
    "reusable": false,
    "interactivity": true
  },
  "editorScript": "file:./index.js",
  "textdomain": "gateway"
}