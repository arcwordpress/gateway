{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gateway/gtx-route",
  "title": "GTX Route",
  "parent": ["gateway/gtx-router"],
  "category": "gateway",
  "icon": "welcome-widgets-menus",
  "description": "Defines a single route within a router. Content inside is displayed when this route is active.",
  "keywords": ["route", "page", "view", "panel"],
  "attributes": {
    "path": {
      "type": "string",
      "default": "/"
    },
    "label": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "html": false,
    "reusable": false,
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "editorScript": "file:./build/index.js",
  "editorStyle": "file:./build/index.css",
  "textdomain": "gateway"
}
