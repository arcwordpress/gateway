{
  "name": "@gateway/gateway-grid",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "esbuild src/index.jsx --bundle --outfile=build/index.js --minify --jsx-factory=h --jsx-fragment=Fragment --define:process.env.NODE_ENV='\"production\"'",
    "dev": "esbuild src/index.jsx --bundle --outfile=build/index.js --sourcemap --watch --jsx-factory=h --jsx-fragment=Fragment --define:process.env.NODE_ENV='\"development\"'"
  },
  "dependencies": {
    "preact": "^10.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
