{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "gateway/dynamic-string",
	"version": "0.1.0",
	"title": "GT Dynamic String",
	"category": "gateway",
	"icon": "text",
	"description": "A dynamic string block that binds to interactive data using wp-text.",
	"example": {},
	"supports": {
		"html": false,
		"interactivity": true
	},
	"textdomain": "gateway",
	"editorScript": "file:./build/index.js",
	"attributes": {
		"contextNamespace": {
			"type": "string",
			"default": ""
		},
		"propertyPath": {
			"type": "string",
			"default": ""
		},
		"fallbackText": {
			"type": "string",
			"default": ""
		}
	}
}
