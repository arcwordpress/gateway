{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "gateway/click-control",
	"title": "GT Click Control",
	"category": "gateway",
	"icon": "button",
	"description": "An interactive button or link that triggers actions in the WordPress Interactivity API context.",
	"keywords": ["button", "click", "interactive", "action", "interactivity"],
	"attributes": {
		"text": {
			"type": "string",
			"default": "Click me"
		},
		"elementType": {
			"type": "string",
			"default": "button",
			"enum": ["button", "a"]
		},
		"namespace": {
			"type": "string",
			"default": ""
		},
		"action": {
			"type": "string",
			"default": ""
		}
	},
	"supports": {
		"html": false,
		"interactivity": true,
		"spacing": {
			"margin": true,
			"padding": true
		},
		"color": {
			"background": true,
			"text": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true
		}
	},
	"editorScript": "file:./build/index.js",
	"editorStyle": "file:./build/index.css",
	"style": "file:./build/style-index.css",
	"viewScriptModule": "file:./build/view.js",
	"textdomain": "gateway"
}
