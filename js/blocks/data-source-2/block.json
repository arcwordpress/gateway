{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gateway/data-source-2",
  "title": "GT Data Source 2",
  "category": "gateway",
  "icon": "database-view",
  "description": "Data source block using @arcwp/gateway-data package with WordPress Interactivity API.",
  "attributes": {
    "collectionSlug": {
      "type": "string",
      "default": ""
    },
    "query": {
      "type": "object",
      "default": {}
    },
    "namespace": {
      "type": "string",
      "default": "gateway/data-source-2"
    }
  },
  "supports": {
    "html": false,
    "interactivity": true
  },
  "editorScript": "file:./build/index.js",
  "editorStyle": "file:./build/index.css",
  "viewScriptModule": "file:./build/view.js",
  "textdomain": "gateway"
}
