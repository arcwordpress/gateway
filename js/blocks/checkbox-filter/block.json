{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "gateway/checkbox-filter",
	"version": "0.1.0",
	"title": "GTX Checkbox Filter",
	"category": "gateway",
	"icon": "filter",
	"description": "A checkbox group filter that works with the Interactivity API to filter data by multiple selections.",
	"example": {},
	"supports": {
		"html": false,
		"interactivity": true
	},
	"textdomain": "gateway",
	"editorScript": "file:./build/index.js",
	"editorStyle": "file:./build/index.css",
	"style": "file:./build/style-index.css",
	"viewScriptModule": "file:./build/view.js",
	"attributes": {
		"title": {
			"type": "string",
			"default": "Filter"
		},
		"filterField": {
			"type": "string",
			"default": ""
		},
		"testOptions": {
			"type": "string",
			"default": "[{\"value\": \"10\", \"label\": \"Size 10\"}, {\"value\": \"11\", \"label\": \"Size 11\"}, {\"value\": \"12\", \"label\": \"Size 12\"}]"
		},
		"useContextSource": {
			"type": "boolean",
			"default": false
		},
		"contextSource": {
			"type": "string",
			"default": "items"
		},
		"valueKey": {
			"type": "string",
			"default": "value"
		},
		"labelKey": {
			"type": "string",
			"default": "label"
		},
		"targetNamespace": {
			"type": "string",
			"default": "gateway/data-source"
		},
		"targetAction": {
			"type": "string",
			"default": "filterBy"
		}
	}
}
