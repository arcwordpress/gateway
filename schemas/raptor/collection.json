{
  "$id": "https://gateway.dev/schemas/collection",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Collection",
  "version": "1.1",
  "type": "object",
  "required": ["key", "table"],
  "properties": {
    "key": { "type": "string", "description": "Snake_case identifier, e.g. event" },
    "table": { "type": "string", "description": "DB table name, e.g. gateway_events" },
    "title": { "type": "string" },
    "titlePlural": { "type": "string" },
    "package": { "type": "string", "default": "default" },
    "core": { "type": "boolean", "default": false },
    "private": { "type": "boolean", "default": false },
    "timestamps": { "type": "boolean", "default": true },
    "searchable": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Field keys that are full-text searchable"
    }
  }
}