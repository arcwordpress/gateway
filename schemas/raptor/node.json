{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RaptorNode",
  "type": "object",
  "required": ["id", "type", "position"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique node identifier"
    },
    "type": {
      "type": "string",
      "description": "Node type key — maps to a registered GatewayRaptor node"
    },
    "position": {
      "type": "object",
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "data": {
      "type": "object",
      "description": "Arbitrary node payload — collection record, settings, etc.",
      "additionalProperties": true
    },
    "graph_id": {
      "type": "string",
      "description": "Which graph/canvas this node belongs to"
    }
  }
}