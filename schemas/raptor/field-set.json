{
  "$id": "https://gateway.dev/schemas/field-set",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Field Set",
  "version": "1.0",
  "type": "object",
  "required": ["key", "fields"],
  "properties": {
    "key": { "type": "string", "description": "Unique identifier, e.g. event" },
    "title": { "type": "string" },
    "fields": {
      "type": "array",
      "description": "All fields owned by this object",
      "items": { "$ref": "https://gateway.dev/schemas/field-type" }
    }
  }
}