{
  "$id": "https://gateway.dev/schemas/field-type",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Field Type",
  "type": "object",
  "required": ["name", "type"],
  "properties": {
    "name": { "type": "string" },
    "type": { "type": "string" },
    "label": { "type": "string" },
    "hint": { "type": "string" },
    "required": { "type": "boolean", "default": false },
    "fillable": { "type": "boolean", "default": true },
    "default": {}
  }
}