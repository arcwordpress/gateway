{
  "$id": "https://gateway.dev/schemas/field-group",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Field Group",
  "version": "1.0",
  "type": "object",
  "required": ["key", "fields"],
  "properties": {
    "key": { "type": "string" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "fields": {
      "type": "array",
      "description": "Field keys referenced from the parent field set",
      "items": { "type": "string" }
    },
    "display": {
      "type": "string",
      "enum": ["section", "tab", "panel"],
      "default": "section"
    },
    "order": { "type": "integer" }
  }
}