{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gateway/grid",
  "title": "Grid Display",
  "category": "widgets",
  "icon": "grid-view",
  "description": "Display a Gateway collection as a filterable grid.",
  "keywords": ["gateway", "grid", "collection", "table", "data"],
  "textdomain": "gateway",
  "attributes": {
    "collection":          { "type": "string",  "default": "" },
    "perPage":             { "type": "number",  "default": 20 },
    "colorScheme":         { "type": "string",  "default": "light" },
    "defaultView":         { "type": "string",  "default": "table" },
    "showFilters":         { "type": "boolean", "default": true },
    "showFacetToggle":     { "type": "boolean", "default": true },
    "enableTableView":     { "type": "boolean", "default": true },
    "enableListView":      { "type": "boolean", "default": true },
    "enableCardsView":     { "type": "boolean", "default": true },
    "hiddenFields":        { "type": "array",   "default": [], "items": { "type": "string" } },
    "recordViewMode":      { "type": "string",  "default": "modal" },
    "recordLinkPattern":   { "type": "string",  "default": "" },
    "actionsEnabled":      { "type": "boolean", "default": false },
    "actionRoles":         { "type": "array",   "default": ["administrator"], "items": { "type": "string" } },
    "createActionEnabled": { "type": "boolean", "default": false },
    "createRolesInherit":  { "type": "boolean", "default": true },
    "createActionRoles":   { "type": "array",   "default": ["administrator"], "items": { "type": "string" } },
    "updateActionEnabled": { "type": "boolean", "default": false },
    "updateRolesInherit":  { "type": "boolean", "default": true },
    "updateActionRoles":   { "type": "array",   "default": ["administrator"], "items": { "type": "string" } },
    "deleteActionEnabled": { "type": "boolean", "default": false },
    "deleteRolesInherit":  { "type": "boolean", "default": true },
    "deleteActionRoles":   { "type": "array",   "default": ["administrator"], "items": { "type": "string" } }
  },
  "supports": {
    "html": false,
    "align": ["wide", "full"]
  }
}
